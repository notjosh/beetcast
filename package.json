{
  "name": "beetcast",
  "version": "0.2.3",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,vite -c blue,magenta \"tsx watch src/index.ts | pnpm pino-pretty\" \"vite\"",
    "dev:server": "tsx watch src/index.ts | pnpm pino-pretty",
    "dev:frontend": "vite",
    "start": "node --import tsx/esm src/index.ts",
    "build": "tsc && vite build",
    "build:frontend": "vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p frontend/tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "format:check": "prettier --check .",
    "version:patch": "pnpm version patch --no-git-tag-version",
    "version:minor": "pnpm version minor --no-git-tag-version",
    "version:major": "pnpm version major --no-git-tag-version"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "bandcamp-fetch": "^3.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "got": "^14.6.6",
    "hono": "^4.12.0",
    "lucide-react": "^0.575.0",
    "node-id3": "^0.2.9",
    "pino": "^10.3.1",
    "podcast": "^2.0.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.6.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
