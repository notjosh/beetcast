amends "package://github.com/jdx/hk/releases/download/v1.36.0/hk@1.36.0#/Config.pkl"

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps {
      ["prettier"] {
        glob = List("*.ts", "*.tsx", "*.js", "*.json", "*.css", "*.md")
        check = "pnpm prettier --check {{files}}"
        fix = "pnpm prettier --write {{files}}"
      }
      ["eslint"] {
        glob = List("*.ts", "*.tsx", "*.js")
        check = "pnpm eslint {{files}}"
        fix = "pnpm eslint --fix {{files}}"
      }
      ["typecheck"] {
        check = "pnpm typecheck"
      }
    }
  }
}
